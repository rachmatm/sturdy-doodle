# AI Logo Generator — environment configuration
# Copy this file to .env.local and fill in the values below.
#   cp .env.example .env.local
#
# All variables are read server-side only (inside API route handlers); none are
# exposed to the browser bundle. Do not commit .env.local.

# --- Required (at least one provider's key) ---

# Mistral API key (server-side only). Get one at https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Image provider & fallback ---

# Ordered, comma-separated list of image providers to try per logo, e.g.
#   IMAGE_PROVIDER=pixazo,mistral
# For each prompt the AI service walks providers in this order — and every key
# within a provider (below) — returning the first success, so a rate-limited
# free-tier key (429) rolls over to the next key/provider. Defaults to mistral.
IMAGE_PROVIDER=

# Extra Mistral keys for fallback, comma-separated (tried after MISTRAL_API_KEY).
MISTRAL_API_KEYS=

# Pixazo FLUX.1 Schnell key(s), server-side only. Get one at https://pixazo.ai/
# PIXAZO_API_KEY holds one; PIXAZO_API_KEYS holds extra comma-separated fallbacks.
PIXAZO_API_KEY=
PIXAZO_API_KEYS=

# --- Optional ---

# Reuse a pre-created image-generation agent instead of creating one per process.
# Leave blank to have the AI service create and cache an agent on first use.
MISTRAL_AGENT_ID=

# Directory for generated image bytes (kept outside ./public, served via
# /api/images/[filename]). Defaults to ./storage/uploads when unset.
STORAGE_DIR=

# SQLite database file for saved logo records. Defaults to
# ./storage/gallery.db when unset.
DATABASE_PATH=
