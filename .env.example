# AI Logo Generator — environment configuration
# Copy this file to .env.local and fill in the values below.
#   cp .env.example .env.local
#
# All variables are read server-side only (inside API route handlers); none are
# exposed to the browser bundle. Do not commit .env.local.

# --- Required (at least one provider's key) ---

# Mistral API key (server-side only). Get one at https://console.mistral.ai/
MISTRAL_API_KEY=

# --- Storage backend (auto-selected at runtime) ---
#
# The app picks its storage backend from the environment, so the same build runs
# on a persistent-disk host or on Vercel's ephemeral/serverless filesystem:
#
#   Database — Turso (libSQL) when BOTH TURSO_AUTH_TOKEN and TURSO_DATABASE_URL
#   are set; otherwise local SQLite (better-sqlite3, ./storage/gallery.db).
#
#   Images — Vercel Blob when BOTH BLOB_STORE_ID and BLOB_READ_WRITE_TOKEN are
#   set; otherwise the local filesystem (./storage/uploads).
#
# Leave a pair blank to use the local default. On Vercel, set both pairs (the
# Blob pair is injected automatically when you attach a Blob store).

# Turso / libSQL cloud database. Create one at https://turso.tech/
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel Blob store (public read). Injected automatically by `vercel link` +
# attaching a Blob store; set manually for local Blob testing.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
# --- Image provider & fallback ---

# Ordered, comma-separated list of image providers to try per logo, e.g.
#   IMAGE_PROVIDER=pixazo,mistral
# For each prompt the AI service walks providers in this order — and every key
# within a provider (below) — returning the first success, so a rate-limited
# free-tier key (429) rolls over to the next key/provider. Defaults to mistral.
IMAGE_PROVIDER=

# Extra Mistral keys for fallback, comma-separated (tried after MISTRAL_API_KEY).
MISTRAL_API_KEYS=

# Pixazo FLUX.1 Schnell key(s), server-side only. Get one at https://pixazo.ai/
# PIXAZO_API_KEY holds one; PIXAZO_API_KEYS holds extra comma-separated fallbacks.
PIXAZO_API_KEY=
PIXAZO_API_KEYS=

# How the provider×key chain is ordered per request:
#   fallback (default) — always start at the first provider/key (strict priority),
#                        rolling over to the next only on failure.
#   round-robin        — advance the starting provider AND key per request, so a
#                        fan-out burst (the 12 concurrent calls per /api/generate)
#                        spreads across providers/keys instead of hammering one
#                        free-tier key. Full rollover is preserved either way.
IMAGE_KEY_STRATEGY=

# --- Bot protection (Cloudflare Turnstile) ---
#
# Verification is OPT-IN: the server checks tokens only when TURNSTILE_SECRET_KEY
# is set below. Leave it blank and submissions are unprotected (the widget still
# renders, but nothing is enforced) — handy for local dev. Set it to turn the
# bot check on for /api/generate and /api/refine.

# Public site key — rendered into the browser, so it is NOT a secret. Optional:
# defaults to the project's configured key when blank. Inlined at BUILD time
# (Next.js NEXT_PUBLIC_ rule), so changing it requires a rebuild.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key (server-side only) from the SAME Turnstile widget. Required to
# actually verify tokens. For local testing, Cloudflare's always-passing test
# secret is 1x0000000000000000000000000000000AA (pair with site key
# 1x00000000000000000000AA).
TURNSTILE_SECRET_KEY=

# --- Optional ---

# Pin a specific image-generation agent. Leave blank (recommended): the AI
# service creates an agent on first use, persists its id in the database, and on
# later runs reuses that agent if it still exists upstream (verified via the
# list-agents endpoint) — so it won't pile up duplicate agents across restarts.
# Set this only to force a specific agent and bypass that auto-managed flow.
MISTRAL_AGENT_ID=

# Directory for generated image bytes (kept outside ./public, served via
# /api/images/[filename]). Used only by the local filesystem backend (i.e. when
# the Blob vars above are unset). Defaults to ./storage/uploads.
STORAGE_DIR=

# SQLite database file for saved logo records. Used only by the local SQLite
# backend (i.e. when the Turso vars above are unset). Defaults to
# ./storage/gallery.db.
DATABASE_PATH=
